{
  "name": "posture-critic-app",
  "version": "0.1.1",
  "description": "AI-powered posture analysis for gym, office, and correction exercises",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build": "eas build",
    "preview": "eas build --platform ios --profile preview",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "^50.0.0",
    "expo-camera": "^14.1.0",
    "expo-media-library": "^16.0.0",
    "expo-secure-store": "^12.3.0",
    "expo-router": "^3.4.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "react-native-screens": "~3.28.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-gesture-handler": "~2.14.0",

    "@google/generative-ai": "^0.12.0",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/react": "18.2.45",
    "@types/react-native": "0.72.8",
    "typescript": "5.3.3",
    "eslint": "^8.56.0",
    "eslint-config-universe": "^12.0.0"
  },
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  }
}
