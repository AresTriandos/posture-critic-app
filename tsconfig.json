{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["ES2018"],
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": ["react-native"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}
